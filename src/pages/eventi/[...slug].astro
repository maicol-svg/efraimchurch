---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const events = await getCollection('eventi');
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const formattedDate = new Intl.DateTimeFormat('it-IT', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(event.data.date);

const mapsQuery = event.data.location
  ? encodeURIComponent(event.data.location)
  : '';
---

<BaseLayout
  title={event.data.title}
  description={event.data.description}
  image={event.data.image}
>
  <article class="pt-32 pb-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <!-- Back link -->
      <a
        href="/eventi/"
        class="inline-flex items-center gap-2 text-sm font-medium text-primary-dark hover:text-primary transition-colors mb-8 group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Torna agli eventi
      </a>

      <!-- Header -->
      <header class="mb-10">
        <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-text leading-tight">
          {event.data.title}
        </h1>

        <!-- Event meta -->
        <div class="mt-6 flex flex-col gap-3">
          <div class="inline-flex items-center gap-2 text-text-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <time datetime={event.data.date.toISOString()} class="capitalize">
              {formattedDate}
            </time>
          </div>

          {event.data.time && (
            <div class="inline-flex items-center gap-2 text-text-secondary">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Ore {event.data.time}
            </div>
          )}

          {event.data.location && (
            <div class="inline-flex items-start gap-2 text-text-secondary">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <a
                href={`https://www.google.com/maps/search/?api=1&query=${mapsQuery}`}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-primary-dark hover:underline transition-colors"
              >
                {event.data.location}
              </a>
            </div>
          )}
        </div>
      </header>

      {/* Featured image */}
      {event.data.image && (
        <img
          src={event.data.image}
          alt={event.data.title}
          class="w-full aspect-video object-cover rounded-2xl mb-12"
          loading="eager"
        />
      )}

      {/* External link / CTA */}
      {event.data.link && (
        <div class="mb-10 p-5 rounded-xl bg-cream border border-divider flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <div class="flex-1">
            <p class="text-sm font-medium text-text">
              Vuoi partecipare a questo evento?
            </p>
          </div>
          <a
            href={event.data.link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-primary-dark px-6 py-2.5 text-sm font-semibold text-white transition-all duration-300 hover:bg-primary hover:shadow-lg shrink-0"
          >
            Iscriviti / Maggiori info
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
          </a>
        </div>
      )}

      <!-- Content -->
      <div class="prose prose-lg max-w-none
        prose-headings:font-serif prose-headings:text-text
        prose-p:text-text-secondary prose-p:leading-relaxed
        prose-a:text-primary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-text
        prose-img:rounded-xl
        prose-blockquote:border-l-accent prose-blockquote:text-text-secondary">
        <Content />
      </div>

      <!-- Bottom back link -->
      <div class="mt-16 pt-8 border-t border-divider">
        <a
          href="/eventi/"
          class="inline-flex items-center gap-2 text-sm font-medium text-primary-dark hover:text-primary transition-colors group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Torna agli eventi
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
