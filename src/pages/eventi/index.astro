---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allEvents = await getCollection('eventi');
const now = new Date();
now.setHours(0, 0, 0, 0);

const futureEvents = allEvents
  .filter((e) => new Date(e.data.date).getTime() >= now.getTime())
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const pastEvents = allEvents
  .filter((e) => new Date(e.data.date).getTime() < now.getTime())
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('it-IT', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
}

function getDay(date: Date): string {
  return date.getDate().toString();
}

function getMonth(date: Date): string {
  return new Intl.DateTimeFormat('it-IT', { month: 'short' }).format(date).toUpperCase();
}
---

<BaseLayout
  title="Eventi"
  description="Scopri gli eventi e le attivita della Chiesa Cristiana Evangelica Efraim di Messina."
>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-br from-primary-dark via-primary to-primary-light pt-36 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-black/10"></div>
    <div
      class="absolute inset-0 opacity-10"
      style="background: repeating-linear-gradient(-45deg, transparent, transparent 80px, rgba(255,255,255,0.05) 80px, rgba(255,255,255,0.05) 82px);"
    ></div>
    <div
      class="absolute -bottom-2 left-0 right-0 h-24 bg-warm"
      style="clip-path: polygon(0 60%, 100% 0, 100% 100%, 0% 100%);"
    ></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl font-bold text-white tracking-tight">
        Eventi
      </h1>
      <div class="flex items-center justify-center gap-4 mt-6 mb-4">
        <span class="block w-12 h-px bg-accent"></span>
        <span class="block w-2 h-2 rounded-full bg-accent"></span>
        <span class="block w-12 h-px bg-accent"></span>
      </div>
      <p class="text-lg sm:text-xl text-white/90 font-light max-w-2xl mx-auto">
        Momenti di incontro, crescita e celebrazione insieme
      </p>
    </div>
  </section>

  <!-- Prossimi Eventi -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-text mb-12">
        Prossimi eventi
      </h2>

      {futureEvents.length > 0 ? (
        <div class="space-y-8">
          {futureEvents.map((event) => (
            <article class="group relative flex flex-col md:flex-row rounded-2xl bg-white border border-divider overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
              {/* Date badge */}
              <div class="flex md:flex-col items-center justify-center bg-primary-dark text-white px-6 py-4 md:px-8 md:py-6 md:min-w-[120px] shrink-0">
                <span class="text-3xl md:text-4xl font-bold leading-none">
                  {getDay(event.data.date)}
                </span>
                <span class="ml-2 md:ml-0 md:mt-1 text-sm font-semibold uppercase tracking-wider text-white/80">
                  {getMonth(event.data.date)}
                </span>
              </div>

              {/* Content area */}
              <div class="flex flex-col lg:flex-row flex-1">
                <div class="flex-1 p-6 lg:p-8">
                  <h3 class="font-serif text-xl lg:text-2xl font-bold text-text group-hover:text-primary-dark transition-colors">
                    <a href={`/eventi/${event.id}/`} class="hover:underline">
                      {event.data.title}
                    </a>
                  </h3>

                  <div class="flex flex-wrap gap-x-5 gap-y-2 mt-3 text-sm text-text-secondary">
                    {event.data.time && (
                      <span class="inline-flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        {event.data.time}
                      </span>
                    )}
                    {event.data.location && (
                      <span class="inline-flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                        {event.data.location}
                      </span>
                    )}
                    <span class="inline-flex items-center gap-1.5">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                      {formatDate(event.data.date)}
                    </span>
                  </div>

                  <p class="mt-4 text-text-secondary text-sm leading-relaxed line-clamp-2">
                    {event.data.description}
                  </p>

                  <a
                    href={`/eventi/${event.id}/`}
                    class="inline-flex items-center gap-2 mt-5 text-sm font-semibold text-primary-dark hover:text-primary transition-colors group/link"
                  >
                    Scopri di piu
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover/link:translate-x-1" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                </div>

                {/* Image (optional) */}
                {event.data.image && (
                  <a href={`/eventi/${event.id}/`} class="hidden lg:block relative w-64 shrink-0 overflow-hidden">
                    <img
                      src={event.data.image}
                      alt={event.data.title}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-r from-white/20 to-transparent"></div>
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 rounded-2xl bg-cream border border-divider">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-text-secondary/40 mb-4" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          <p class="text-xl text-text-secondary font-light">
            Nessun evento in programma.
          </p>
          <p class="mt-2 text-text-secondary/70">
            Torna a trovarci!
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- Eventi Passati -->
  {pastEvents.length > 0 && (
    <section class="pb-16 sm:pb-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="border-t border-divider pt-16">
          <h2 class="font-serif text-2xl sm:text-3xl font-bold text-text-secondary mb-10">
            Eventi passati
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {pastEvents.map((event) => (
              <article class="group flex flex-col rounded-xl bg-cream/60 border border-divider overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
                {event.data.image && (
                  <a href={`/eventi/${event.id}/`} class="block relative h-40 overflow-hidden">
                    <img
                      src={event.data.image}
                      alt={event.data.title}
                      class="w-full h-full object-cover opacity-80 transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent"></div>
                  </a>
                )}
                <div class="p-5">
                  <time
                    datetime={event.data.date.toISOString()}
                    class="text-xs font-medium text-text-secondary uppercase tracking-wider"
                  >
                    {formatDate(event.data.date)}
                  </time>
                  <h3 class="mt-2 font-serif text-lg font-bold text-text group-hover:text-primary-dark transition-colors">
                    <a href={`/eventi/${event.id}/`} class="hover:underline">
                      {event.data.title}
                    </a>
                  </h3>
                  <p class="mt-2 text-text-secondary text-sm leading-relaxed line-clamp-2">
                    {event.data.description}
                  </p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
