---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPhotos = (await getCollection('galleria'))
  .filter(entry => entry.data.visible !== false)
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));

const categories = [
  { id: 'all', label: 'Tutte' },
  { id: 'kenya', label: 'Kenya' },
  { id: 'india', label: 'India' },
  { id: 'chiesa', label: 'Chiesa' },
  { id: 'eventi', label: 'Eventi' },
];
---

<BaseLayout
  title="Galleria"
  description="Le foto della Chiesa Efraim: dalle missioni in Kenya e India, ai momenti di comunità e agli eventi."
>
  <!-- Hero -->
  <section class="relative bg-slate-dark overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/90 to-slate-dark"></div>
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-accent rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-primary-light rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-28 md:py-36">
      <div class="max-w-3xl">
        <span class="inline-block text-accent font-medium text-sm tracking-widest uppercase mb-4">Le nostre immagini</span>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
          Galleria
        </h1>
        <p class="mt-6 text-lg text-white/70 leading-relaxed max-w-2xl">
          Momenti di vita, servizio e speranza dalla nostra comunità e dalle missioni nel mondo.
        </p>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-20 md:py-28 bg-warm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      <!-- Category filters -->
      <div class="flex flex-wrap gap-3 mb-12 justify-center" id="gallery-filters">
        {categories.map((cat) => (
          <button
            type="button"
            data-filter={cat.id}
            class:list={[
              'gallery-filter px-5 py-2.5 rounded-full text-sm font-medium transition-all',
              cat.id === 'all'
                ? 'bg-primary text-white'
                : 'bg-white text-text-secondary border border-divider/50 hover:border-primary/30 hover:text-primary-dark',
            ]}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Photos grid -->
      {allPhotos.length > 0 ? (
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4" id="gallery-grid">
          {allPhotos.map((foto) => (
            <div
              class="gallery-item group relative aspect-square rounded-xl overflow-hidden cursor-pointer"
              data-category={foto.data.category}
            >
              <img
                src={foto.data.image}
                alt={foto.data.caption || foto.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
                <p class="text-white text-sm font-medium">{foto.data.title}</p>
                {foto.data.caption && (
                  <p class="text-white/70 text-xs mt-1">{foto.data.caption}</p>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-text-secondary text-lg">Nessuna foto nella galleria al momento.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const filters = document.querySelectorAll('.gallery-filter');
  const items = document.querySelectorAll('.gallery-item');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      // Update active button
      filters.forEach((b) => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('bg-white', 'text-text-secondary', 'border', 'border-divider/50');
      });
      btn.classList.remove('bg-white', 'text-text-secondary', 'border', 'border-divider/50');
      btn.classList.add('bg-primary', 'text-white');

      // Filter items
      items.forEach((item) => {
        if (filter === 'all' || item.getAttribute('data-category') === filter) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
