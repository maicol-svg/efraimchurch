---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getRecurringSchedule } from '../lib/events';
import contatti from '../data/contatti.json';

const schedule = await getRecurringSchedule();
const scheduleDesc = schedule.map(s => `${s.title} ${s.day.toLowerCase()} ore ${s.time}`).join(', ');
---

<BaseLayout
  title="Contatti"
  description={`Contatta la Chiesa Cristiana Efraim di ${contatti.citta}. ${contatti.indirizzo}. ${scheduleDesc}.`}
>
  <!-- Hero -->
  <section class="relative bg-slate-dark overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/90 to-slate-dark"></div>
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-accent rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-primary-light rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-28 md:py-36">
      <div class="max-w-3xl">
        <span class="inline-block text-accent font-medium text-sm tracking-widest uppercase mb-4">Siamo qui per te</span>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
          Contattaci
        </h1>
        <p class="mt-6 text-lg text-white/70 leading-relaxed max-w-2xl">
          Hai domande, bisogno di preghiera o vuoi saperne di più sulla nostra chiesa? Siamo felici di ascoltarti.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="py-20 md:py-28 bg-warm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <h2 class="font-serif text-2xl md:text-3xl font-bold text-text mb-2">Scrivici un messaggio</h2>
          <p class="text-text-secondary mb-8">Compila il modulo e ti risponderemo il prima possibile.</p>

          <form
            action="https://formsubmit.co/info@missionekenya.com"
            method="POST"
            class="space-y-6"
          >
            <!-- Formsubmit config -->
            <input type="hidden" name="_subject" value="Nuovo messaggio dal sito Efraim Church" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="https://efraimchurch.com/contatti/?inviato=true" />
            <input type="hidden" name="_template" value="table" />
            <input type="text" name="_honey" style="display:none" />

            <!-- Name -->
            <div>
              <label for="name" class="block text-sm font-medium text-text mb-2">
                Nome e cognome <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                class="w-full rounded-xl border border-divider bg-white px-4 py-3 text-text placeholder:text-text-secondary/50 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors"
                placeholder="Il tuo nome"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-text mb-2">
                Email <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full rounded-xl border border-divider bg-white px-4 py-3 text-text placeholder:text-text-secondary/50 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors"
                placeholder="la.tua@email.com"
              />
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-text mb-2">
                Messaggio <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full rounded-xl border border-divider bg-white px-4 py-3 text-text placeholder:text-text-secondary/50 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors resize-y"
                placeholder="Come possiamo aiutarti?"
              ></textarea>
            </div>

            <!-- Privacy -->
            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                class="mt-1 rounded border-divider text-primary focus:ring-primary"
              />
              <label for="privacy" class="text-sm text-text-secondary">
                Ho letto e accetto la <a href="/privacy-policy/" class="text-primary-dark underline hover:text-primary transition-colors">Privacy Policy</a>. <span class="text-red-500" aria-hidden="true">*</span>
              </label>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-8 py-3.5 text-base font-semibold text-white shadow-md hover:bg-primary-dark hover:shadow-lg transition-all w-full sm:w-auto"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>
              Invia messaggio
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="lg:col-span-2 space-y-8">
          <!-- Address -->
          <div class="bg-white rounded-2xl shadow-sm border border-divider/50 p-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Indirizzo</h3>
                <address class="not-italic mt-1 text-text-secondary leading-relaxed" set:html={`${contatti.indirizzo}<br>(${contatti.zona})<br>${contatti.cap} ${contatti.citta} (${contatti.provincia})`}>
                </address>
              </div>
            </div>
          </div>

          <!-- Email -->
          <div class="bg-white rounded-2xl shadow-sm border border-divider/50 p-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Email</h3>
                <a href={`mailto:${contatti.email}`} class="mt-1 text-primary-dark hover:text-primary transition-colors block">
                  {contatti.email}
                </a>
                {contatti.email_secondaria && (
                  <a href={`mailto:${contatti.email_secondaria}`} class="mt-1 text-primary-dark hover:text-primary transition-colors block">
                    {contatti.email_secondaria}
                  </a>
                )}
              </div>
            </div>
          </div>

          <!-- Worship Times -->
          <div class="bg-white rounded-2xl shadow-sm border border-divider/50 p-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-dark" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Orari culti</h3>
                <div class="mt-2 space-y-2">
                  {schedule.map((s) => (
                    <div class="flex items-center gap-2">
                      <span class="w-2 h-2 rounded-full bg-primary-light shrink-0"></span>
                      <span class="text-text-secondary"><strong class="text-text">{s.day}</strong> - {s.title} ore {s.time}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- How to reach us -->
          <div class="bg-white rounded-2xl shadow-sm border border-divider/50 p-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9Z"/><path d="m3 9 2.45-4.9A2 2 0 0 1 7.24 3h9.52a2 2 0 0 1 1.8 1.1L21 9"/><path d="M12 3v6"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Come raggiungerci</h3>
                <div class="mt-2 text-sm text-text-secondary space-y-2 leading-relaxed">
                  <p><strong class="text-text">In auto:</strong> {contatti.raggiungerci_auto}</p>
                  <p><strong class="text-text">Con i mezzi:</strong> {contatti.raggiungerci_mezzi}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Maps -->
  <section class="bg-cream">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
      <div class="text-center mb-8">
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-text">Dove trovarci</h2>
      </div>
      <div class="rounded-2xl overflow-hidden shadow-sm border border-divider/50 aspect-[16/7]">
        <iframe
          src={contatti.maps_embed}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Mappa della Chiesa Cristiana Efraim - ${contatti.indirizzo}, ${contatti.cap} ${contatti.citta}`}
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
