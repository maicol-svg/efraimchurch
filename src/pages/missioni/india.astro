---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const updates = (await getCollection('missioni'))
  .filter((entry) => entry.data.mission === 'india')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Missione India"
  description="La nostra missione in India. Portiamo istruzione, sostegno e il messaggio del Vangelo alle comunita' rurali indiane."
>
  <!-- Hero -->
  <section class="relative bg-slate-dark overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/90 to-slate-dark"></div>
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-accent rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-primary-light rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-28 md:py-36">
      <div class="max-w-3xl">
        <a href="/missioni/" class="inline-flex items-center gap-2 text-white/60 hover:text-white transition-colors text-sm mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Tutte le missioni
        </a>
        <span class="inline-block text-accent font-medium text-sm tracking-widest uppercase mb-4">India</span>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
          Missione India
        </h1>
        <p class="mt-6 text-lg text-white/70 leading-relaxed max-w-2xl">
          Portare speranza e istruzione alle comunita' rurali dell'India, dove il bisogno e' grande e le opportunita' sono poche.
        </p>
        <div class="flex flex-wrap gap-4 mt-8">
          <div class="flex items-center gap-2 bg-white/10 rounded-full px-4 py-2 text-sm text-white/80">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            India
          </div>
          <div class="flex items-center gap-2 bg-white/10 rounded-full px-4 py-2 text-sm text-white/80">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            Progetto in crescita
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission Description -->
  <section class="py-20 md:py-28 bg-warm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div>
          <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">Il progetto</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-text mb-6">Una nuova frontiera di speranza</h2>
          <div class="space-y-4 text-text-secondary leading-relaxed">
            <p>
              L'India rappresenta una delle nuove frontiere missionarie della Chiesa Efraim. In un Paese dove milioni di persone vivono in condizioni di estrema poverta', sentiamo la chiamata a portare il messaggio di speranza del Vangelo insieme ad un aiuto concreto e tangibile.
            </p>
            <p>
              Il nostro progetto si concentra sulle comunita' rurali, dove l'accesso all'istruzione e ai servizi sanitari di base e' spesso limitato o inesistente. Lavoriamo a stretto contatto con partner locali per garantire che il nostro intervento sia culturalmente sensibile e sostenibile nel lungo periodo.
            </p>
            <p>
              Attraverso programmi educativi, supporto alimentare e formazione professionale, miriamo a creare opportunita' concrete per le famiglie e i bambini delle comunita' che serviamo. Crediamo che ogni persona meriti la possibilita' di una vita dignitosa e piena di speranza.
            </p>
          </div>
        </div>

        <!-- Program Areas -->
        <div class="space-y-6">
          <div class="bg-white rounded-xl p-6 shadow-sm border border-divider/50">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-dark" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Istruzione</h3>
                <p class="mt-1 text-sm text-text-secondary">Programmi educativi per bambini e giovani, con particolare attenzione all'alfabetizzazione e alla formazione professionale.</p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-divider/50">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-dark" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Sostegno alle famiglie</h3>
                <p class="mt-1 text-sm text-text-secondary">Supporto diretto alle famiglie in difficolta' attraverso programmi di microcredito, formazione lavorativa e assistenza sociale.</p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-divider/50">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-dark" aria-hidden="true"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Salute</h3>
                <p class="mt-1 text-sm text-text-secondary">Accesso ai servizi sanitari di base, campagne di prevenzione e sensibilizzazione sulla salute nelle comunita' rurali.</p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-divider/50">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-accent/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-dark" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Cura spirituale</h3>
                <p class="mt-1 text-sm text-text-secondary">Condivisione del Vangelo, formazione di leader locali e creazione di comunita' di fede autosufficienti e radicate nella Parola.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Gallery Placeholder -->
  <section class="py-20 md:py-28 bg-cream">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">Galleria</span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-text">Immagini dalla missione</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {Array.from({ length: 8 }).map((_, i) => (
          <div class="aspect-square rounded-xl bg-white border border-divider/50 flex items-center justify-center overflow-hidden">
            <div class="text-center p-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-accent/20 mb-2" aria-hidden="true">
                <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                <circle cx="9" cy="9" r="2" />
                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
              </svg>
              <p class="text-xs text-text-secondary/50">Foto {i + 1}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Updates -->
  <section class="py-20 md:py-28 bg-warm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">Aggiornamenti</span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-text">Ultime notizie dall'India</h2>
      </div>

      {updates.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {updates.map((update) => (
            <article class="bg-white rounded-xl shadow-sm border border-divider/50 overflow-hidden hover:shadow-md transition-shadow">
              {update.data.images && update.data.images[0] && (
                <div class="aspect-video bg-cream">
                  <img src={update.data.images[0]} alt={update.data.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
              )}
              <div class="p-6">
                <time
                  datetime={update.data.date.toISOString().split('T')[0]}
                  class="text-sm text-accent-dark font-medium"
                >
                  {update.data.date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
                <h3 class="font-serif text-lg font-semibold text-text mt-2">{update.data.title}</h3>
                <p class="mt-2 text-sm text-text-secondary leading-relaxed">{update.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-text-secondary">Nessun aggiornamento disponibile al momento. Torna presto per le ultime novita'!</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA Donate -->
  <section class="py-20 bg-primary-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">Sostieni la missione in India</h2>
      <p class="text-lg text-white/70 mb-8 max-w-2xl mx-auto">
        Il tuo contributo puo' fare una differenza enorme nella vita delle comunita' rurali indiane. Unisciti a noi.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/dona/"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-accent px-8 py-3 text-base font-semibold text-slate-dark shadow-md hover:bg-accent-dark hover:text-white transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          Dona ora
        </a>
        <a
          href="/contatti/"
          class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-white/30 px-8 py-3 text-base font-semibold text-white hover:bg-white/10 transition-all"
        >
          Contattaci per info
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
