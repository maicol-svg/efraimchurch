---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MissionNav from '../../components/MissionNav.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getCollection } from 'astro:content';
import kenya from '../../data/missione-kenya.json';

const galleria = (await getCollection('galleria'))
  .filter(entry => entry.data.category === 'kenya' && (entry.data as any).visible !== false)
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));
const updates = kenya.aggiornamenti;
---

<BaseLayout
  title="Missione Kenya"
  description="La nostra missione a Kasue, Kitui, Kenya. Dal 2012 sosteniamo oltre 140 bambini con istruzione, nutrizione, acqua pulita e cura spirituale."
>
  <MissionNav sections={[
    { id: 'progetto', label: 'Il progetto' },
    { id: 'obiettivi', label: 'Obiettivi' },
    { id: 'adozione', label: 'Sostieni' },
    { id: 'galleria', label: 'Galleria' },
    { id: 'aggiornamenti', label: 'Aggiornamenti' },
  ]} />

  <!-- Section 1: Hero with real photo -->
  <section class="relative bg-slate-dark overflow-hidden">
    <div class="absolute inset-0">
      <img src={kenya.immagine} alt="Missione Kenya - gruppo bambini e volontari" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-dark/90 via-slate-dark/75 to-slate-dark/60"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-28 md:py-36">
      <div class="max-w-3xl">
        <a href="/missioni/" class="inline-flex items-center gap-2 text-white/60 hover:text-white transition-colors text-sm mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Tutte le missioni
        </a>
        <span class="inline-block text-accent font-medium text-sm tracking-widest uppercase mb-4">Kenya - Kasue, Kitui</span>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
          {kenya.titolo}
        </h1>
        <p class="mt-6 text-lg text-white/70 leading-relaxed max-w-2xl">
          {kenya.hero_descrizione}
        </p>
        <div class="flex flex-wrap gap-4 mt-8">
          <div class="flex items-center gap-2 bg-white/10 rounded-full px-4 py-2 text-sm text-white/80">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            Kasue, Kitui
          </div>
          <div class="flex items-center gap-2 bg-white/10 rounded-full px-4 py-2 text-sm text-white/80">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            Dal 2012
          </div>
          <div class="flex items-center gap-2 bg-white/10 rounded-full px-4 py-2 text-sm text-white/80">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            140+ bambini
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 mt-10">
          <a
            href="#adozione"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-accent px-8 py-3 text-base font-semibold text-slate-dark shadow-md hover:bg-accent-dark hover:text-white transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            Adotta un bambino
          </a>
          <a
            href="#adozione"
            class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-white/30 px-8 py-3 text-base font-semibold text-white hover:bg-white/10 transition-all"
          >
            Dona ora
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Il progetto -->
  <section id="progetto" class="py-20 md:py-28 bg-warm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div>
          <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">Il nostro lavoro</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-text mb-6">Trasformare vite a Kasue</h2>
          <div class="space-y-4 text-text-secondary leading-relaxed">
            {kenya.descrizione.map((paragrafo) => (
              <p>{paragrafo}</p>
            ))}
          </div>
        </div>

        <!-- Program Areas -->
        <div class="space-y-6">
          <div class="bg-white rounded-xl p-6 shadow-sm border border-divider/50">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Istruzione</h3>
                <p class="mt-1 text-sm text-text-secondary">Scuola primaria e secondaria, materiale didattico, insegnanti qualificati e supporto scolastico per tutti i bambini del programma.</p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-divider/50">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/><path d="M8.5 8.5v.01"/><path d="M16 15.5v.01"/><path d="M12 12v.01"/><path d="M11 17v.01"/><path d="M7 14v.01"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Nutrizione</h3>
                <p class="mt-1 text-sm text-text-secondary">Pasti caldi quotidiani preparati con ingredienti locali, programmi di sicurezza alimentare e formazione nutrizionale per le famiglie.</p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-divider/50">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 14.69c1.1 0 2-0.86 2-1.94 0-.54-.27-1.06-.8-1.49-.53-.42-.92-1.06-1.06-1.56-.14.5-.53 1.14-1.06 1.56-.53.43-.8.95-.8 1.49 0 1.08.9 1.94 2 1.94z"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Acqua pulita</h3>
                <p class="mt-1 text-sm text-text-secondary">Costruzione e manutenzione di pozzi per garantire accesso ad acqua potabile sicura alla comunità di Kasue e ai villaggi circostanti.</p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-divider/50">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-text">Cura spirituale</h3>
                <p class="mt-1 text-sm text-text-secondary">Attività spirituali, insegnamento biblico, service comunitari e accompagnamento pastorale per bambini, giovani e famiglie.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Obiettivi -->
  {(kenya.obiettivi_raggiunti?.length > 0 || kenya.obiettivi_da_raggiungere?.length > 0) && (
    <section id="obiettivi" class="py-20 md:py-28 bg-cream">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">Il nostro percorso</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-text">Obiettivi della missione</h2>
          <p class="mt-4 text-text-secondary leading-relaxed max-w-2xl mx-auto">
            Ogni traguardo raggiunto è un passo verso un futuro migliore.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-5xl mx-auto">
          {kenya.obiettivi_raggiunti?.length > 0 && (
            <div>
              <h3 class="font-serif text-xl font-bold text-primary-dark mb-6 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                Obiettivi raggiunti
              </h3>
              <ul class="space-y-4">
                {kenya.obiettivi_raggiunti.map((obj: string) => (
                  <li class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center shrink-0 mt-0.5">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="m5 12 5 5L20 7"/></svg>
                    </div>
                    <span class="text-text-secondary">{obj}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {kenya.obiettivi_da_raggiungere?.length > 0 && (
            <div>
              <h3 class="font-serif text-xl font-bold text-accent-dark mb-6 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                Obiettivi da raggiungere
              </h3>
              <ul class="space-y-4">
                {kenya.obiettivi_da_raggiungere.map((obj: string) => (
                  <li class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full border-2 border-accent/40 shrink-0 mt-0.5"></div>
                    <span class="text-text-secondary">{obj}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <div class="mt-12 text-center">
          <a href="/dona/" class="inline-flex items-center justify-center gap-2 rounded-full bg-accent px-8 py-3 text-base font-semibold text-slate-dark shadow-md hover:bg-accent-dark hover:text-white transition-all">
            Sostieni un obiettivo
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Section 4: Sostieni questa missione -->
  <section id="adozione" class="py-20 md:py-28 bg-cream">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Adozione card -->
          <div class="bg-white rounded-2xl shadow-sm border border-divider/50 p-8 flex flex-col">
            <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3 class="font-serif text-2xl font-bold text-text mb-3">Adotta un bambino</h3>
            <p class="text-text-secondary leading-relaxed mb-6 flex-1">
              Accompagna un bambino di Kasue nel suo percorso di crescita. Con il tuo sostegno mensile garantisci scuola, cibo e cure mediche.
            </p>
            <a href="/adozioni/#form-adozione" class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-8 py-3 text-base font-semibold text-white shadow-md hover:bg-primary-dark hover:shadow-lg transition-all">
              Adotta a distanza
            </a>
          </div>
          <!-- Donazione card -->
          <div class="bg-white rounded-2xl shadow-sm border border-divider/50 p-8 flex flex-col">
            <div class="w-14 h-14 rounded-full bg-accent/10 flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent-dark" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            </div>
            <h3 class="font-serif text-2xl font-bold text-text mb-3">Fai una donazione</h3>
            <p class="text-text-secondary leading-relaxed mb-6 flex-1">
              Dona beni concreti, sostieni un progetto o fai una donazione libera. Ogni contributo cambia la vita di un bambino a Kasue.
            </p>
            <a href="/dona/" class="inline-flex items-center justify-center gap-2 rounded-full bg-accent px-8 py-3 text-base font-semibold text-slate-dark shadow-md hover:bg-accent-dark hover:text-white transition-all">
              Vai alla pagina donazioni
            </a>
          </div>
        </div>
        <!-- Causale note -->
        <div class="mt-8 p-4 rounded-lg bg-primary/5 border border-primary/10 text-center">
          <p class="text-sm text-text-secondary">
            <strong class="text-text">Causale bonifico:</strong> Donazione - Missione Kenya
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: Galleria -->
  {galleria.length > 0 && (
    <section id="galleria" class="py-20 md:py-28 bg-warm">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">Galleria</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-text">Immagini dalla missione</h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {galleria.map((foto) => (
            <div class="aspect-square rounded-xl overflow-hidden">
              <img
                src={foto.data.image}
                alt={foto.data.caption || foto.data.title || 'Foto dalla missione in Kenya'}
                class="w-full h-full object-cover"
                loading="lazy"
                data-lightbox-group="kenya"
                data-lightbox-title={foto.data.title}
                data-lightbox-caption={foto.data.caption || ''}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Section 7: Aggiornamenti -->
  <section id="aggiornamenti" class="py-20 md:py-28 bg-warm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block text-accent-dark font-medium text-sm tracking-widest uppercase mb-3">Aggiornamenti</span>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-text">Ultime notizie dal Kenya</h2>
      </div>

      {updates.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {updates.map((update) => (
            <article class="bg-white rounded-xl shadow-sm border border-divider/50 overflow-hidden hover:shadow-md transition-shadow">
              {update.immagini && update.immagini[0] && (
                <div class="aspect-video bg-cream">
                  <img src={update.immagini[0]} alt={update.titolo} class="w-full h-full object-cover" loading="lazy" />
                </div>
              )}
              <div class="p-6">
                <time
                  datetime={update.data}
                  class="text-sm text-accent-dark font-medium"
                >
                  {new Date(update.data).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
                <h3 class="font-serif text-lg font-semibold text-text mt-2">{update.titolo}</h3>
                <p class="mt-2 text-sm text-text-secondary leading-relaxed">{update.descrizione}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-text-secondary">Nessun aggiornamento disponibile al momento. Torna presto per le ultime novità!</p>
        </div>
      )}
    </div>
  </section>

  <!-- Section 8: CTA finale -->
  <section class="py-20 bg-primary-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">Hai domande sulla missione in Kenya?</h2>
      <p class="text-lg text-white/70 mb-8 max-w-2xl mx-auto">
        Contattaci per saperne di più su come sosteniamo i bambini di Kasue e su come puoi fare la differenza.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contatti/"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-accent px-8 py-3 text-base font-semibold text-slate-dark shadow-md hover:bg-accent-dark hover:text-white transition-all"
        >
          Contattaci
        </a>
        <a
          href="/missioni/"
          class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-white/30 px-8 py-3 text-base font-semibold text-white hover:bg-white/10 transition-all"
        >
          Tutte le missioni
        </a>
      </div>
    </div>
  </section>
  <Lightbox />
</BaseLayout>
