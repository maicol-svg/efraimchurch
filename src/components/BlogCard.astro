---
interface Props {
  title: string;
  date: Date;
  description: string;
  image?: string;
  href: string;
}

const { title, date, description, image, href } = Astro.props;

const postDate = new Date(date);

const monthNames = [
  'gennaio', 'febbraio', 'marzo', 'aprile', 'maggio', 'giugno',
  'luglio', 'agosto', 'settembre', 'ottobre', 'novembre', 'dicembre',
];

const formattedDate = `${postDate.getDate()} ${monthNames[postDate.getMonth()]} ${postDate.getFullYear()}`;
---

<article class="group flex flex-col overflow-hidden bg-white border border-divider shadow-sm transition-all duration-400 hover:-translate-y-1 hover:shadow-lg blog-card">
  <!-- Image -->
  {image ? (
    <a href={href} class="block relative h-48 overflow-hidden" tabindex="-1" aria-hidden="true">
      <img
        src={image}
        alt=""
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
    </a>
  ) : (
    <a href={href} class="block relative h-48 overflow-hidden" tabindex="-1" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/30 via-primary/20 to-accent/10"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-primary/20"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
      </div>
    </a>
  )}

  <!-- Content -->
  <div class="flex flex-col flex-1 p-6">
    <time datetime={postDate.toISOString()} class="text-[11px] font-sans font-medium text-text-secondary uppercase tracking-[0.15em]">
      {formattedDate}
    </time>

    <h3 class="font-serif text-xl font-semibold text-text mt-2.5 mb-3 group-hover:text-primary-dark transition-colors duration-300 line-clamp-2 leading-snug">
      <a href={href}>
        {title}
      </a>
    </h3>

    <p class="text-sm text-text-secondary leading-relaxed line-clamp-3 flex-1">
      {description}
    </p>

    <a
      href={href}
      class="group/link inline-flex items-center gap-3 mt-5 font-sans text-sm font-semibold text-primary-dark tracking-wide transition-colors hover:text-accent"
    >
      <span class="w-10 h-px bg-primary-dark group-hover/link:bg-accent group-hover/link:w-14 transition-all duration-300"></span>
      Leggi
    </a>
  </div>
</article>

<style>
  .blog-card {
    border-bottom: 3px solid transparent;
    transition: border-color 0.3s, box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .blog-card:hover {
    border-bottom-color: var(--color-accent);
  }
</style>
