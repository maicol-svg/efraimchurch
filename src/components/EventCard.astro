---
interface Props {
  title: string;
  date: Date;
  time?: string;
  description: string;
  image?: string;
  href: string;
}

const { title, date, time, description, href } = Astro.props;

const eventDate = new Date(date);

const day = eventDate.getDate();

const monthNames = ['Gen', 'Feb', 'Mar', 'Apr', 'Mag', 'Giu', 'Lug', 'Ago', 'Set', 'Ott', 'Nov', 'Dic'];
const month = monthNames[eventDate.getMonth()];

const dayNames = ['Domenica', 'Lunedì', 'Martedì', 'Mercoledì', 'Giovedì', 'Venerdì', 'Sabato'];
const dayName = dayNames[eventDate.getDay()];
---

<article class="card-editorial group flex gap-6 bg-white p-6">
  <!-- Date column -->
  <div class="flex-shrink-0 flex flex-col items-center w-16">
    <span class="font-serif text-4xl font-semibold text-accent leading-none">{day}</span>
    <span class="text-[11px] font-sans font-medium text-text-secondary uppercase tracking-[0.15em] mt-1">{month}</span>
  </div>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <h3 class="font-serif text-lg font-semibold text-text group-hover:text-primary-dark transition-colors duration-300 leading-snug">
      <a href={href}>
        {title}
      </a>
    </h3>

    <div class="flex items-center gap-2 mt-1.5 text-sm text-text-secondary">
      <span>{dayName}</span>
      {time && (
        <>
          <span class="text-accent">&middot;</span>
          <span>ore {time}</span>
        </>
      )}
    </div>

    <p class="text-sm text-text-secondary mt-3 line-clamp-2 leading-relaxed">
      {description}
    </p>
  </div>
</article>
