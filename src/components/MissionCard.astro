---
interface Props {
  title: string;
  country: string;
  image: string;
  description: string;
  stats: Array<{ label: string; value: string }>;
  href: string;
}

const { title, country, image, description, stats, href } = Astro.props;
---

<article class="group relative overflow-hidden bg-white/5 border border-white/10 transition-all duration-400 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/20 hover:border-white/20 hover:border-l-accent"
  style="border-left: 3px solid transparent; transition: border-color 0.3s, box-shadow 0.4s cubic-bezier(0.16,1,0.3,1), transform 0.4s cubic-bezier(0.16,1,0.3,1);">
  <!-- Image area -->
  <div class="relative h-56 overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-slate-dark via-slate-dark/40 to-transparent"></div>

    <!-- Country label -->
    <div class="absolute top-5 left-5">
      <span class="text-[11px] font-sans font-medium text-white/80 uppercase tracking-[0.15em]">
        {country}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6">
    <h3 class="font-serif text-xl font-semibold text-white mb-4 group-hover:text-accent transition-colors duration-300">
      {title}
    </h3>

    <!-- Stats row -->
    {stats.length > 0 && (
      <div class="flex gap-6 mb-5 pb-5 border-b border-white/10">
        {stats.map((stat) => (
          <div>
            <span class="block font-serif text-3xl font-semibold text-accent leading-none">{stat.value}</span>
            <span class="block text-[11px] font-sans text-white/50 uppercase tracking-[0.15em] mt-1.5">{stat.label}</span>
          </div>
        ))}
      </div>
    )}

    <p class="text-white/60 text-sm leading-relaxed mb-6 line-clamp-3">
      {description}
    </p>

    <a
      href={href}
      class="group/link inline-flex items-center gap-3 font-sans text-sm font-semibold text-accent tracking-wide transition-colors hover:text-white"
    >
      <span class="w-10 h-px bg-accent group-hover/link:w-14 group-hover/link:bg-white transition-all duration-300"></span>
      Scopri di pi&ugrave;
    </a>
  </div>
</article>

<style>
  article:hover {
    border-left-color: var(--color-accent) !important;
  }
</style>
