---
interface Props {
  name: string;
  role: string;
  image?: string;
  bio?: string;
}

const { name, role, image, bio } = Astro.props;
---

<article class="group bg-white rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden border border-divider/50">
  <div class="p-8 flex flex-col items-center text-center">
    <!-- Image -->
    <div class="w-28 h-28 rounded-full overflow-hidden bg-cream border-4 border-primary-light/20 mb-5 group-hover:border-accent/40 transition-colors duration-300">
      {image ? (
        <img
          src={image}
          alt={`Foto di ${name}`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-light/10 to-primary/10">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary/40" aria-hidden="true">
            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" />
            <circle cx="12" cy="7" r="4" />
          </svg>
        </div>
      )}
    </div>

    <!-- Name -->
    <h3 class="font-serif text-xl font-semibold text-text">{name}</h3>

    <!-- Role badge -->
    <span class="inline-block mt-2 px-4 py-1 rounded-full bg-primary/10 text-primary-dark text-sm font-medium">
      {role}
    </span>

    <!-- Bio -->
    {bio && (
      <p class="mt-4 text-sm text-text-secondary leading-relaxed">
        {bio}
      </p>
    )}
  </div>
</article>
