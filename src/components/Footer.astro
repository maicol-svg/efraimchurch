---
import { getRecurringSchedule } from '../lib/events';

const currentYear = new Date().getFullYear();
const schedule = await getRecurringSchedule();

const quickLinks = [
  { href: '/chi-siamo/', label: 'Chi siamo' },
  { href: '/missioni/', label: 'Missioni' },
  { href: '/eventi/', label: 'Eventi' },
  { href: '/blog/', label: 'Blog' },
  { href: '/dona/', label: 'Dona' },
  { href: '/contatti/', label: 'Contatti' },
];
---

<footer class="bg-slate-dark text-white/80" role="contentinfo">
  <!-- Decorative top element: gold line + text mark -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-6 pt-16 pb-12">
      <div class="w-16 h-px bg-accent" aria-hidden="true"></div>
      <span class="font-serif text-[13px] tracking-[0.2em] uppercase text-accent/80">Efraim</span>
      <div class="flex-1 h-px bg-white/5" aria-hidden="true"></div>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-10">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-6" aria-label="Efraim Church">
          <span class="font-serif text-4xl font-bold tracking-[0.04em] text-white block">EFRAIM</span>
          <span class="font-serif text-[15px] italic font-light text-white/40 mt-1 block">Equipaggiare vite, trasformare comunità</span>
        </a>
        <p class="text-sm text-white/50 leading-relaxed">
          Chiesa Cristiana Evangelica Efraim.
        </p>
        <!-- Social -->
        <div class="flex gap-3 mt-8">
          <a href="https://www.facebook.com/profile.php?id=100089926218971" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/8 flex items-center justify-center hover:bg-accent transition-colors" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/efraim.church/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/8 flex items-center justify-center hover:bg-accent transition-colors" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href="https://www.youtube.com/@EfraimChurch" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/8 flex items-center justify-center hover:bg-accent transition-colors" aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
          </a>
          <a href="https://tiktok.com" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/8 flex items-center justify-center hover:bg-accent transition-colors" aria-label="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 8v8a5 5 0 0 1-5 5H8a5 5 0 0 1-5-5V8a5 5 0 0 1 5-5h8a5 5 0 0 1 5 5Z"/><path d="M10 12a3 3 0 1 0 3 3V6c.3 1.8 1.7 3 3.5 3"/></svg>
          </a>
        </div>
      </div>

      <!-- Link rapidi -->
      <div>
        <h3 class="font-sans text-[11px] tracking-[0.15em] uppercase text-white/40 mb-6">Link rapidi</h3>
        <ul class="space-y-3" role="list">
          {quickLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="group flex items-center gap-0 text-sm text-white/60 hover:text-accent transition-all">
                <span class="w-0 group-hover:w-3 h-px bg-accent transition-all duration-300 mr-0 group-hover:mr-2"></span>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contatti -->
      <div>
        <h3 class="font-sans text-[11px] tracking-[0.15em] uppercase text-white/40 mb-6">Contatti</h3>
        <address class="not-italic space-y-4 text-sm text-white/60 border-l border-accent/30 pl-4">
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5 text-accent/60" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Via Bartolomeo Colleoni 43<br>(zona Minissale)<br>98125 Messina (ME)</span>
          </div>
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-accent/60" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <a href="mailto:info@efraimchurch.com" class="hover:text-accent transition-colors">info@efraimchurch.com</a>
          </div>
        </address>
      </div>

      <!-- Orari -->
      <div>
        <h3 class="font-sans text-[11px] tracking-[0.15em] uppercase text-white/40 mb-6">Orari culti</h3>
        <div class="border border-white/8 p-5">
          <!-- Gold corner marks -->
          <div class="relative">
            <div class="absolute -top-5 -left-5 w-3 h-3 border-t border-l border-accent/50" aria-hidden="true"></div>
            <div class="absolute -top-5 -right-5 w-3 h-3 border-t border-r border-accent/50" aria-hidden="true"></div>
            <div class="absolute -bottom-5 -left-5 w-3 h-3 border-b border-l border-accent/50" aria-hidden="true"></div>
            <div class="absolute -bottom-5 -right-5 w-3 h-3 border-b border-r border-accent/50" aria-hidden="true"></div>

            <div class="space-y-4 text-sm">
              {schedule.map((s, i) => (
                <>
                  {i > 0 && <div class="w-full h-px bg-white/8" aria-hidden="true"></div>}
                  <div class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5 text-accent" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <div>
                      <p class="text-white font-medium text-[13px] tracking-wide">{s.day}</p>
                      <p class="text-white/50 text-[13px]">{s.title} ore {s.time}</p>
                    </div>
                  </div>
                </>
              ))}
            </div>
          </div>
        </div>

        <a
          href="https://www.youtube.com/@EfraimChurch"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 mt-6 text-sm text-accent hover:text-white transition-colors"
        >
          <span class="w-6 group-hover:w-10 h-px bg-accent transition-all duration-300" aria-hidden="true"></span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 3 14 9-14 9V3z"/></svg>
          Segui la diretta
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-14 pt-8 border-t border-accent/20 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-white/35">
      <p>&copy; {currentYear} Chiesa Cristiana Evangelica Efraim &mdash; C.F. 97089710830</p>
      <a href="/privacy-policy/" class="hover:text-white/60 transition-colors tracking-wide">Privacy Policy</a>
    </div>
  </div>
</footer>
